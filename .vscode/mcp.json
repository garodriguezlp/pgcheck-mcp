{
  "servers": {
    "pgcheck-mcp": {
      "type": "stdio",
      "command": "jbang",
      "args": ["PgcheckMcpServer.java"],
      "env": {
        "QUARKUS_DATASOURCE_JDBC_URL": "jdbc:postgresql://localhost:5432/postgres",
        "QUARKUS_DATASOURCE_USERNAME": "postgres",
        "QUARKUS_DATASOURCE_PASSWORD": "postgres"
      }
    }
  }
}
